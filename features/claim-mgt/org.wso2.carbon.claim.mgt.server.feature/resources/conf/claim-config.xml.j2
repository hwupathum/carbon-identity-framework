<ClaimConfig>
    <Dialects>
        {% for dialect in dialects %}
        <Dialect dialectURI="{{ dialect.uri }}">
            {% for claim in dialect.claims %}
            <Claim>
                {% for property_name, property_value in claim.properties.items() %}
                {% if property_value is boolean and property_value or property_value|string|lower == "true" %}
                <{{ property_name }}/>
                {% else %}
                <{{ property_name }}>{{ property_value }}</{{ property_name }}>
                {% endif %}
                {% endfor %}
            </Claim>
            {% endfor %}
        </Dialect>
        {% endfor %}
    </Dialects>
</ClaimConfig>
